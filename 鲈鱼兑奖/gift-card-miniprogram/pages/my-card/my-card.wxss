.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #141414 100%);
  padding: 30px 20px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding-top: 150px;
}

.empty-icon {
  width: 100px;
  height: 100px;
  line-height: 100px;
  border-radius: 50%;
  background: #1c1c1e;
  margin: 0 auto 24px;
  font-size: 48px;
}

.title {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 12px;
  text-align: center;
}

.desc {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 32px;
  text-align: center;
}

.btn-claim {
  width: 200px;
  padding: 14px 0;
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
}

/* 卡片详情 */
.card-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 横向卡片展示 */
.card-display {
  width: 100%;
  max-width: 360px;
  aspect-ratio: 16/10;
  margin-bottom: 24px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(212, 168, 83, 0.2);
}

.card-img {
  width: 100%;
  height: 100%;
}

/* 兑奖码区域 */
.code-section {
  width: 100%;
  max-width: 360px;
  text-align: center;
  margin-bottom: 20px;
}

.code-section .label {
  display: block;
  font-size: 13px;
  color: #888;
  margin-bottom: 8px;
}

.code-box {
  background: #1c1c1e;
  border: 1px solid #3a3a3c;
  border-radius: 12px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code {
  font-size: 24px;
  font-weight: 700;
  color: #d4a853;
  letter-spacing: 3px;
  font-family: 'Courier New', monospace;
}

.copy-hint {
  font-size: 11px;
  color: #666;
  margin-top: 6px;
}

/* 信息区域 */
.info-section {
  width: 100%;
  max-width: 360px;
  background: #1c1c1e;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 20px;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid #2a2a2a;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item .label {
  font-size: 13px;
  color: #666;
}

.info-item .value {
  font-size: 13px;
  color: #fff;
}

.info-item .status {
  font-size: 13px;
  color: #34c759;
}

/* 操作按钮 */
.actions {
  width: 100%;
  max-width: 360px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.btn-redeem {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
  border-radius: 12px;
  padding: 14px 0;
  font-size: 15px;
  font-weight: 600;
}

.btn-copy {
  background: #1c1c1e;
  color: #fff;
  border: 1px solid #3a3a3c;
  border-radius: 12px;
  padding: 14px 0;
  font-size: 15px;
}

.btn-share {
  background: transparent;
  color: #d4a853;
  border: 1px solid #d4a853;
  border-radius: 12px;
  padding: 14px 0;
  font-size: 15px;
}

/* 提示 */
.tips {
  text-align: center;
  padding: 0 20px;
}

.tips text {
  font-size: 11px;
  color: #666;
  line-height: 1.6;
}
