.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #141414 100%);
  padding: 40px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 3D卡片舞台 */
.card-stage {
  width: 100%;
  max-width: 360px;
  aspect-ratio: 16/10;
  perspective: 1000px;
  margin-bottom: 30px;
}

.card-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  animation: autoRotate 6s ease-in-out infinite;
}

@keyframes autoRotate {
  0%, 15% {
    transform: rotateY(0deg);
  }
  35%, 65% {
    transform: rotateY(180deg);
  }
  85%, 100% {
    transform: rotateY(360deg);
  }
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(212, 168, 83, 0.3);
}

.card-front {
  transform: rotateY(0deg);
}

.card-back {
  transform: rotateY(180deg);
}

.card-img {
  width: 100%;
  height: 100%;
}

/* 品牌区域 */
.brand {
  text-align: center;
  margin-bottom: 32px;
}

.brand-name {
  display: block;
  font-size: 26px;
  font-weight: 700;
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8px;
}

.brand-desc {
  font-size: 14px;
  color: #666;
}

/* 按钮区域 */
.actions {
  width: 100%;
  max-width: 300px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 32px;
}

.btn-primary {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
  border-radius: 12px;
  padding: 16px 0;
  font-size: 16px;
  font-weight: 600;
}

.btn-secondary {
  background: #1c1c1e;
  color: #fff;
  border: 1px solid #3a3a3c;
  border-radius: 12px;
  padding: 16px 0;
  font-size: 16px;
}

/* 活动说明 */
.info-section {
  width: 100%;
  max-width: 300px;
  background: #1c1c1e;
  border-radius: 16px;
  padding: 20px;
}

.info-title {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid #2a2a2a;
}

.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10px;
}

.info-item:last-child {
  margin-bottom: 0;
}

.dot {
  color: #d4a853;
  margin-right: 8px;
  font-size: 14px;
}

.text {
  font-size: 13px;
  color: #888;
  line-height: 1.5;
}
