/* 全局样式 */
page {
  background-color: #0a0a0a;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

/* 主色调 */
:root {
  --gold: #d4a853;
  --gold-light: #e8c87a;
  --bg-dark: #0a0a0a;
  --bg-card: #1c1c1e;
  --text-secondary: #a0a0a0;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
  color: #0a0a0a;
  border-radius: 16px;
  font-weight: 600;
  padding: 16px 32px;
  text-align: center;
}

.btn-secondary {
  background: #1c1c1e;
  color: #fff;
  border: 1px solid #3a3a3c;
  border-radius: 16px;
  padding: 16px 32px;
  text-align: center;
}

/* 容器 */
.container {
  padding: 24px;
}

/* 标题 */
.title {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 16px;
}

.subtitle {
  font-size: 14px;
  color: var(--text-secondary);
}
