.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #141414 100%);
  padding: 30px 20px;
}

/* 加载中 */
.loading {
  text-align: center;
  padding-top: 200px;
}

.loading text {
  color: #666;
  font-size: 14px;
}

/* 已领取/空状态 */
.claimed-tip,
.empty-tip {
  text-align: center;
  padding-top: 150px;
}

.icon {
  width: 80px;
  height: 80px;
  line-height: 80px;
  border-radius: 50%;
  background: #1c1c1e;
  margin: 0 auto 24px;
  font-size: 36px;
}

.claimed-tip .icon {
  color: #34c759;
}

.empty-tip .icon {
  color: #ff9500;
}

.title {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 12px;
  text-align: center;
}

.desc {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 32px;
  text-align: center;
}

/* 领取表单 */
.claim-form {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 横向卡片预览 */
.card-preview {
  width: 100%;
  max-width: 360px;
  aspect-ratio: 16/10;
  margin-bottom: 24px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(212, 168, 83, 0.2);
}

.card-img {
  width: 100%;
  height: 100%;
}

/* 用户信息 */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  margin-bottom: 8px;
  border: 2px solid #d4a853;
}

.nickname {
  font-size: 15px;
  color: #fff;
}

/* 领取信息 */
.claim-info {
  text-align: center;
  margin-bottom: 28px;
}

.claim-info .title {
  font-size: 17px;
  margin-bottom: 14px;
}

.claim-info .desc {
  display: block;
  font-size: 13px;
  color: #888;
  margin-bottom: 6px;
  text-align: center;
}

/* 按钮 */
.btn-claim,
.btn-get-user,
.btn-view {
  width: 280px;
  padding: 14px 0;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12px;
}

.btn-claim {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
}

.btn-claim[disabled] {
  opacity: 0.6;
}

.btn-get-user {
  background: #1c1c1e;
  color: #fff;
  border: 1px solid #3a3a3c;
}

.btn-view {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
}
