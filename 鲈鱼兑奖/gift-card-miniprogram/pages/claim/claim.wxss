.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0a 0%, #141414 100%);
  padding: 30px 20px;
}

/* 加载中 */
.loading {
  text-align: center;
  padding-top: 200px;
}

.loading text {
  color: #666;
  font-size: 14px;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding-top: 150px;
}

.empty-tip .icon {
  color: #ff9500;
}

.icon {
  width: 80px;
  height: 80px;
  line-height: 80px;
  border-radius: 50%;
  background: #1c1c1e;
  margin: 0 auto 24px;
  font-size: 36px;
}

.title {
  display: block;
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 12px;
  text-align: center;
}

.desc {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 32px;
  text-align: center;
}

/* 领取表单 */
.claim-form {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 横向卡片预览 */
.card-preview {
  width: 100%;
  max-width: 360px;
  aspect-ratio: 16/10;
  margin-bottom: 24px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(212, 168, 83, 0.2);
}

.card-img {
  width: 100%;
  height: 100%;
}

/* 输入区域 */
.input-section {
  width: 100%;
  max-width: 320px;
  margin-bottom: 20px;
}

.code-input {
  width: 100%;
  height: 52px;
  background: #1c1c1e;
  border: 1px solid #3a3a3c;
  border-radius: 12px;
  padding: 0 16px;
  font-size: 18px;
  color: #fff;
  text-align: center;
  letter-spacing: 2px;
  box-sizing: border-box;
}

.code-input::placeholder {
  color: #666;
  font-size: 14px;
  letter-spacing: 0;
}

/* 兑换码信息 */
.code-info {
  background: #1c1c1e;
  border-radius: 12px;
  padding: 16px 24px;
  margin-bottom: 20px;
  text-align: center;
  min-width: 200px;
}

.code-info .label {
  display: block;
  font-size: 12px;
  color: #888;
  margin-bottom: 6px;
}

.code-info .code {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #d4a853;
  letter-spacing: 2px;
  margin-bottom: 6px;
}

.code-info .status {
  display: block;
  font-size: 12px;
  color: #34c759;
}

/* 表单区域 */
.form-section {
  width: 100%;
  max-width: 320px;
  background: #1c1c1e;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.form-title {
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 20px;
  display: block;
}

.form-item {
  margin-bottom: 16px;
}

.form-item .label {
  display: block;
  font-size: 13px;
  color: #888;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 46px;
  background: #2a2a2a;
  border: 1px solid #3a3a3c;
  border-radius: 10px;
  padding: 0 14px;
  font-size: 15px;
  color: #fff;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #666;
}

.btn-choose-avatar {
  width: 80px;
  height: 80px;
  background: #2a2a2a;
  border: 1px dashed #3a3a3c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #888;
  padding: 0;
}

.btn-choose-avatar text {
  font-size: 11px;
}

.avatar-preview {
  width: 72px;
  height: 72px;
  border-radius: 50%;
}

/* 领取信息 */
.claim-info {
  text-align: center;
  margin-bottom: 28px;
}

.claim-info .title {
  font-size: 17px;
  margin-bottom: 14px;
}

.claim-info .desc {
  display: block;
  font-size: 13px;
  color: #888;
  margin-bottom: 6px;
  text-align: center;
  white-space: pre-line;
}

/* 按钮 */
.btn-verify,
.btn-get-user,
.btn-claim {
  width: 280px;
  padding: 16px 0;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 12px;
}

.btn-verify {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
}

.btn-verify[disabled] {
  opacity: 0.6;
}

.btn-get-user {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
  border: none;
}

.btn-claim {
  background: linear-gradient(135deg, #d4a853 0%, #e8c87a 100%);
  color: #0a0a0a;
}

.btn-claim[disabled] {
  opacity: 0.6;
}

/* 用户信息 */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20px;
}

.avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  margin-bottom: 8px;
  border: 2px solid #d4a853;
}

.nickname {
  font-size: 15px;
  color: #fff;
}

/* 提示 */
.tips {
  text-align: center;
  padding: 0 30px;
  margin-top: 20px;
}

.tips text {
  font-size: 12px;
  color: #666;
  line-height: 1.8;
  white-space: pre-line;
}
