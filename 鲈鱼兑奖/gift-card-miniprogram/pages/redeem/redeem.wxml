<view class="container">
  <!-- 成功状态 -->
  <view class="success-state" wx:if="{{redeemed}}">
    <view class="success-icon">✓</view>
    <text class="success-title">兑奖成功！</text>
    <text class="success-desc">我们将尽快安排发货，请保持电话畅通</text>
    <button class="btn-home" bindtap="goHome">返回首页</button>
  </view>

  <!-- 兑奖表单 -->
  <view class="redeem-form" wx:else>
    <!-- 卡片信息 -->
    <view class="card-info">
      <image src="/images/2.png" mode="aspectFit" class="card-img"/>
      <view class="code-display">
        <text class="label">兑奖码</text>
        <text class="code">{{code}}</text>
      </view>
    </view>

    <!-- 表单 -->
    <view class="form-section">
      <view class="form-title">填写收货信息</view>

      <view class="form-item">
        <text class="label">收货人</text>
        <input 
          type="text" 
          placeholder="请输入姓名" 
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>

      <view class="form-item">
        <text class="label">手机号</text>
        <input 
          type="number" 
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="form-item">
        <text class="label">收货地址</text>
        <textarea 
          placeholder="请输入详细地址（省市区+街道+门牌号）" 
          value="{{address}}"
          bindinput="onAddressInput"
        />
      </view>

      <view class="form-item">
        <text class="label">备注（选填）</text>
        <input 
          type="text" 
          placeholder="如：请电话联系、周末配送等" 
          value="{{remark}}"
          bindinput="onRemarkInput"
        />
      </view>
    </view>

    <!-- 提交按钮 -->
    <button 
      class="btn-submit" 
      bindtap="submitRedeem"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '确认兑奖'}}
    </button>

    <!-- 提示 -->
    <view class="tips">
      <text>• 提交后我们将尽快安排发货\n• 有问题请联系客服微信：Lighten36</text>
    </view>
  </view>
</view>
